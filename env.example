# Copy to .env or pass to Docker: docker compose --env-file env.example up --build
# PostgreSQL (consumer + postgres service)
POSTGRES_PASSWORD=notification

# Default OpenMRS organization used by the local demo.
DEFAULT_ORGANIZATION_KEY=default
DEFAULT_ORGANIZATION_NAME=Default Organization
DEFAULT_ORGANIZATION_TIMEZONE=UTC

# Scheduler that publishes due pending notifications to RabbitMQ.
SCHEDULER_POLL_INTERVAL_SECONDS=30
SCHEDULER_BATCH_SIZE=25

# Grafana (dashboard container)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# OpenTelemetry
# Overridden in docker-compose for producer/consumer to target otel-collector.
# Keep these for local/manual runs.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# 32-byte AES key, Base64-encoded (openssl rand -base64 32)
SECRETS_MASTER_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# One-time seed: written encrypted to Postgres when the secrets table is empty.
# Align with FakeComWorld / your provider docs.
SECRETS_SEED_SWIFTSEND_API_KEY=your-api-key-here
SECRETS_SEED_SECUREPOST_CLIENT_ID=securepost-client-id
SECRETS_SEED_SECUREPOST_CLIENT_SECRET=securepost-secret-key
SECRETS_SEED_LEGACYLINK_USERNAME=legacylink-user
SECRETS_SEED_LEGACYLINK_PASSWORD=legacylink-password
SECRETS_SEED_ASYNCFLOW_API_KEY=asyncflow-api-key
