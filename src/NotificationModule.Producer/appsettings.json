{
  "RabbitMq": {
    "Host": "localhost",
    "Port": "5672",
    "Username": "guest",
    "Password": "guest"
  },
  "NotificationDb": {
    "ConnectionString": "Host=localhost;Port=5432;Database=notification;Username=notification;Password=notification"
  },
  "Organizations": {
    "Default": {
      "Key": "default",
      "Name": "Default Organization",
      "TimeZone": "UTC",
      "PreferredProvider": "SwiftSend",
      "FallbackProviders": "SecurePost,LegacyLink,AsyncFlow"
    }
  },
  "ApiKeys": {
    "Seed": {
      "Default": ""
    }
  },
  "Scheduler": {
    "PollIntervalSeconds": 30,
    "BatchSize": 25
  },
  "DataRetention": {
    "RetentionDays": 14,
    "RunIntervalHours": 24,
    "BillingRetentionDays": 365
  },
  "OpenTelemetry": {
    "ServiceName": "notification-producer",
    "Environment": "local",
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "Logging": {
    "LogLevel": { "Default": "Information" }
  }
}
